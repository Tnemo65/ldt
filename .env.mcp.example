# ============================================================
# MCP Servers Environment Configuration
# CA-DQStream Project
# ============================================================
# Copy this file to .env.mcp and fill in your credentials.
# This file is git-ignored.
# ============================================================

# --- Grafana MCP Server ---
# Create a service account in Grafana: Administration → Service Accounts
# Grant "Admin" role for full access, or "Editor" for read + limited write
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=your_grafana_service_account_token_here

# --- PostgreSQL MCP Server ---
# Direct connection to postgres (bypasses pgbouncer)
# Alternative: postgresql://cadqstream:cadqstream123@localhost:6432/dq_pipeline (via pgbouncer)
POSTGRES_CONNECTION=postgresql://cadqstream:cadqstream123@localhost:5432/dq_pipeline

# For restricted (read-only) mode, use --access-mode=restricted in config
# Unrestricted enables full read/write including DDL and DML
POSTGRES_ACCESS_MODE=unrestricted

# --- Kafka MCP Server ---
# Broker addresses (comma-separated for multiple brokers)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kafka-mcp-server
KAFKA_SASL_MECHANISM=
KAFKA_TLS_ENABLE=false
# For SASL auth, uncomment and fill:
# KAFKA_USERNAME=your_kafka_username
# KAFKA_PASSWORD=your_kafka_password

# --- MinIO MCP Server ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# --- Prometheus MCP Server ---
# For local Prometheus
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_LOG_LEVEL=ERROR

# For AWS Managed Prometheus, uncomment and fill:
# AWS_PROFILE=your_aws_profile
# AWS_REGION=us-east-1
# PROMETHEUS_WORKSPACE_ID=ws-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Confluent MCP Server ---
# Full path to the mcp-confluent directory (MUST BE ABSOLUTE PATH on Windows)
CONFLUENT_MCP_PATH=C:/proj/ldt/mcp-confluent
# API key for Confluent Cloud (leave empty for local-only usage)
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
# For Confluent Cloud with OAuth:
# CONFLUENT_CLOUD_CLIENT_ID=
# CONFLUENT_CLOUD_CLIENT_SECRET=
# CONFLUENT_CLOUD_TOKEN_URL=
