\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Memory-based anomaly scoring pipeline. Each incoming record $\mathbf  {x}_t$ is normalized, encoded to $\mathbf  {z}_t \in \mathbb  {R}^{34}$, compared against $K=10$ nearest neighbors in the FIFO memory buffer via L1 distance, and normalized against the per-context threshold $\beta _{\text  {ctx}}$. Records with normalized score $\geq 1.0$ are flagged as anomalies.\relax }}{28}{figure.caption.15}}
\newlabel{fig:memory_scoring}{{4.2}{28}{Memory-based anomaly scoring pipeline. Each incoming record $\mathbf {x}_t$ is normalized, encoded to $\mathbf {z}_t \in \mathbb {R}^{34}$, compared against $K=10$ nearest neighbors in the FIFO memory buffer via L1 distance, and normalized against the per-context threshold $\beta _{\text {ctx}}$. Records with normalized score $\geq 1.0$ are flagged as anomalies.\relax }{figure.caption.15}{}}
