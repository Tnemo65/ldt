# =============================================================================
# CA-DQStream + MemStream v5 - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# Generate secure keys with: openssl rand -hex 32
# =============================================================================

# ==================== SECURITY KEYS ====================
# Model signing key (256-bit hex) - REQUIRED
# Generate with: openssl rand -hex 32
MEMSTREAM_MODEL_SIGNING_KEY=change-me-to-256-bit-secret-key

# IEC (Intelligent Error Correction) signing key (256-bit hex) - REQUIRED
# Generate with: openssl rand -hex 32
IEC_SIGNING_KEY=change-me-to-another-256-bit-secret-key

# ==================== REDIS ====================
REDIS_PASSWORD=change-me-to-secure-redis-password

# ==================== MINIO / S3-Compatible Storage (replaces PostgreSQL) ====================
MINIO_SECRET_KEY=minioadmin

# ==================== GRAFANA ====================
GRAFANA_PASSWORD=admin123

# ==================== FLINK ====================
# Parallelism for Flink operators
FLINK_PARALLELISM=4

# ==================== DATA ====================
# Path to data directory (relative to deployment folder)
DATA_DIR=./data

# ==================== KAFKA ====================
# Kafka retention in hours
KAFKA_RETENTION_HOURS=168

# Number of partitions for topics
KAFKA_PARTITIONS=4
