\@writefile{lof}{\contentsline {figure}{\numberline {6.2}{\ignorespaces Multi-metric performance comparison of anomaly detection algorithms. The Proposed Context-Aware sklearn IsolationForest achieves the best FPR (2.99\% weighted average) among all algorithms, with F1 = 0.71 weighted average across Easy/Medium/Hard difficulty levels. The Easy-difficulty benchmark results (5 seeds) show F1 = 0.83 and FPR = 2.99\% for the proposed method. All metrics meet or exceed the production targets (FPR $<$ 5\%, Recall $\geq $ 75\%).}}{47}{figure.caption.30}\protected@file@percent }
\newlabel{fig:model_radar}{{6.2}{47}{Multi-metric performance comparison of anomaly detection algorithms. The Proposed Context-Aware sklearn IsolationForest achieves the best FPR (2.99\% weighted average) among all algorithms, with F1 = 0.71 weighted average across Easy/Medium/Hard difficulty levels. The Easy-difficulty benchmark results (5 seeds) show F1 = 0.83 and FPR = 2.99\% for the proposed method. All metrics meet or exceed the production targets (FPR $<$ 5\%, Recall $\geq $ 75\%)}{figure.caption.30}{}}
\newlabel{sec:rq2_conclusion_full}{{6.4.2}{47}{Experiment 4: Comparison with Existing DQ Tools}{figure.caption.30}{}}
