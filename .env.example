# =============================================================================
# MCP Servers Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Confluent Cloud / Kafka + Flink
# Required for: mcp-confluent
# Install: npx -y @confluentinc/mcp-confluent
# Docs: https://github.com/confluentinc/mcp-confluent
# -----------------------------------------------------------------------------

# --- Confluent Cloud (production) ---
# Get from: https://confluent.cloud/environments/<env_id>/keys
CONFLUENT_CLOUD_API_KEY=your_confluent_cloud_api_key
CONFLUENT_CLOUD_API_SECRET=your_confluent_cloud_api_secret

# Environment & cluster IDs (from Confluent Cloud dashboard)
CONFLUENT_ENVIRONMENT_ID=env-xxxxxxxx
CONFLUENT_CLUSTER_ID=lkc-xxxxxxxxx
CONFLUENT_CLUSTER_REGION=us-east-1

# --- Local / on-prem Kafka development ---
# Used for local Confluent Platform or Docker Compose
# Minimal config for local-only tools (list-topics, produce, consume, list-schemas)
BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_ENDPOINT=http://localhost:8081

# Optional: Schema Registry auth
SCHEMA_REGISTRY_API_KEY=your_sr_api_key
SCHEMA_REGISTRY_API_SECRET=your_sr_api_secret

# Optional: REST Proxy & Connect endpoints
KAFKA_REST_ENDPOINT=http://localhost:8082
KAFKA_CONNECT_ENDPOINT=http://localhost:8083

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# Required for: minio
# Install: npx -y @pickstar-2002/minio-mcp@latest
# Docs: https://github.com/pickstar-2002/minio-mcp
# -----------------------------------------------------------------------------

# MinIO server endpoint (without http://)
# For local Docker: localhost:9000
# For MinIO console port: 9001 (not used here)
MINIO_ENDPOINT=localhost:9000

# MinIO access credentials
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Comma-separated list of bucket names to expose (leave empty for all accessible buckets)
MINIO_BUCKETS=bucket1,bucket2

# Set to "true" for HTTPS (required for most production MinIO deployments)
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Grafana (with Prometheus as datasource)
# Required for: grafana
# Install: uvx mcp-grafana  (requires: pip install uv or curl -LsSf https://astral.sh/uv/install.sh | sh)
# Docs: https://github.com/grafana/mcp-grafana
# Notes:
#   - Prometheus is accessed via Grafana's Prometheus datasource
#   - Requires Grafana 9.0+ with a Service Account token
#   - Create token: Grafana UI -> My Account -> Service Accounts -> Add service account
# -----------------------------------------------------------------------------

# Grafana instance URL
GRAFANA_URL=http://localhost:3000

# Grafana Service Account token (with Viewer or Editor permissions)
# Requires: Grafana Server Admin or Editor role + datasource query permissions
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
