FROM python:3.10-slim
WORKDIR /app
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends liblz4-1 && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir kafka-python==2.0.2 minio>=7.0.0 lz4>=4.0.0
COPY e2e_test_injector.py /app/e2e_test_injector.py

# Default: run full test suite
CMD ["python3", "/app/e2e_test_injector.py", "--bootstrap", "kafka:9092"]
