# ============================================================
# CA-DQStream Training + Evaluation Docker Image
# ============================================================
# Build: docker build -t ldt-train-eval -f deployment/scripts/Dockerfile.train-eval ..
# Run:   docker run --rm -v c:/proj/ldt/data:/data -v c:/proj/ldt/scripts:/out \
#            --network host ldt-train-eval \
#            --train /data/prod/train_oct2024.parquet ...
# ============================================================
FROM python:3.10-slim

WORKDIR /app

# Install system deps
RUN apt-get update && apt-get install -y \
    gcc liblz4-1 \
    && rm -rf /var/lib/apt/lists/*

# PyTorch (CPU) + deps
RUN pip install --no-cache-dir \
    torch --extra-index-url https://download.pytorch.org/whl/cpu \
    "numpy>=1.24.0" \
    "pyarrow" \
    "scikit-learn>=1.3.0" \
    "pandas>=2.0.0" \
    "boto3>=1.34.0"

# Copy script
COPY scripts/train_eval_prod.py /app/train_eval_prod.py

ENTRYPOINT ["python", "/app/train_eval_prod.py"]
