# =============================================================================
# CA-DQStream Production Deployment - Environment Variables
# All credentials and connection strings for the entire stack
# =============================================================================

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_REST_HOST=localhost
KAFKA_REST_PORT=8082
# Kafka TLS/SASL credentials (generate keystore with deployment/kafka/generate-certs.sh)
KAFKA_SSL_PASSWORD=changeKafkaSSL123
KAFKA_SSL_KEY_PASSWORD=changeKafkaSSL123
KAFKA_USER=kafka-user
KAFKA_PASSWORD=change-kafka-password

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis TLS password — must match REDIS_PASSWORD below
REDIS_PASSWORD=change-redis-password

# ── Schema Registry ───────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_REGISTRY_HOST_NAME=schema-registry

# ── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_API_ENDPOINT=http://minio:9000
MINIO_CONSOLE_ENDPOINT=http://minio:9001
# Secure credentials (generated via: openssl rand -hex 32)
MINIO_ROOT_USER=changeme-minio-user
MINIO_ROOT_PASSWORD=changeme-minio-password-32chars!!
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1
AWS_S3_ENDPOINT=http://minio:9000

# ── MinIO Client (minio-init) ───────────────────────────────────────────────
# Separate credentials for mc client operations
MC_MINIO_USER=${MINIO_ROOT_USER}
MC_MINIO_PASSWORD=${MINIO_ROOT_PASSWORD}

# ── Flink ───────────────────────────────────────────────────────────────────
FLINK_JOB_MANAGER_RPC_ADDRESS=flink-jobmanager
FLINK_JOB_MANAGER_REST_PORT=8081
FLINK_TASK_MANAGER_NUMBER_OF_TASK_SLOTS=4
FLINK_PARALLELISM_DEFAULT=4
FLINK_STATE_BACKEND=filesystem
FLINK_CHECKPOINT_INTERVAL=45000
FLINK_ENV=production
FLINK_PARALLELISM=4

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION_DAYS=15

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=changeme-grafana-password!!

# ── Kafka Topics ──────────────────────────────────────────────────────────────
TOPIC_RAW=taxi-nyc-raw
TOPIC_PROCESSED=dq-stream-processed
TOPIC_ANOMALIES=dq-stream-anomalies
TOPIC_META=dq-meta-stream
TOPIC_IEC=iec-action-replay
TOPIC_METRICS=dq-metrics
TOPIC_VIOLATIONS=dq-hard-rule-violations

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_PARALLELISM=4
PIPELINE_CHECKPOINT_INTERVAL_MS=45000
PIPELINE_WATERMARK_IDLENESS_SECONDS=30
PIPELINE_DEDUP_TTL_DAYS=7

# ── IEC Config ───────────────────────────────────────────────────────────────
IEC_ADWIN_DELTA=0.002
IEC_STRATEGY_THRESHOLD=3
IEC_MODEL_RETRAIN_INTERVAL_MINUTES=60
IEC_METRIC_WINDOW_MINUTES=1

# ── Internal API ───────────────────────────────────────────────────────────────
# Bearer token for ML service authentication (generate via: openssl rand -hex 32)
INTERNAL_API_KEY=changeme-internal-api-key!!
METRICS_API_KEY=changeme-metrics-api-key!!

# ── MemStream (REQUIRED for migration) ──────────────────────────────────────
# Model signing key for integrity verification (generate via: openssl rand -hex 32)
MEMSTREAM_MODEL_SIGNING_KEY=changeme-memstream-signing-key!!
# IEC signing key for action replay authentication
IEC_SIGNING_KEY=changeme-iec-signing-key!!secure32
# MemStream model dimensions
MEMSTREAM_IN_DIM=34
MEMSTREAM_HIDDEN_DIM=68
MEMSTREAM_MEMORY_LEN=50000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS=false
