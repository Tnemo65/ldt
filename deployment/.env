# =============================================================================
# CA-DQStream Production Deployment - Environment Variables
# All credentials and connection strings for the entire stack
# =============================================================================

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_REST_HOST=localhost
KAFKA_REST_PORT=8082

# ── Schema Registry ───────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://schema-registry:8081
SCHEMA_REGISTRY_HOST_NAME=schema-registry

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_API_ENDPOINT=http://minio:9000
MINIO_CONSOLE_ENDPOINT=http://minio:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_S3_ENDPOINT=http://minio:9000

# ── Flink ────────────────────────────────────────────────────────────────────
FLINK_JOB_MANAGER_RPC_ADDRESS=flink-jobmanager
FLINK_JOB_MANAGER_REST_PORT=8081
FLINK_TASK_MANAGER_NUMBER_OF_TASK_SLOTS=4
FLINK_PARALLELISM_DEFAULT=4
FLINK_STATE_BACKEND=filesystem
FLINK_CHECKPOINT_INTERVAL=45000
FLINK_ENV=production

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts/
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION_DAYS=15

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ── Kafka Topics ──────────────────────────────────────────────────────────────
TOPIC_RAW=taxi-nyc-raw
TOPIC_PROCESSED=dq-stream-processed
TOPIC_ANOMALIES=dq-stream-anomalies
TOPIC_META=dq-meta-stream
TOPIC_IEC=iec-action-replay
TOPIC_METRICS=dq-metrics
TOPIC_VIOLATIONS=dq-hard-rule-violations

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_PARALLELISM=4
PIPELINE_CHECKPOINT_INTERVAL_MS=45000
PIPELINE_WATERMARK_IDLENESS_SECONDS=30
PIPELINE_DEDUP_TTL_DAYS=7

# ── IEC Config ───────────────────────────────────────────────────────────────
IEC_ADWIN_DELTA=0.002
IEC_STRATEGY_THRESHOLD=3
IEC_MODEL_RETRAIN_INTERVAL_MINUTES=60
IEC_METRIC_WINDOW_MINUTES=1
