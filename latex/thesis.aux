\@writefile{lof}{\contentsline {figure}{\numberline {2.1}{\ignorespaces Comparison of fare and distance distributions between Standard (RatecodeID$=1$) and Special (RatecodeID$\neq  $1) ratecode groups on January 2024 data. Special trips have significantly higher median fares and greater variance, justifying the context-aware approach.}}{3}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:f3_normal_vs_special}{{2.1}{3}{Comparison of fare and distance distributions between Standard (RatecodeID$=1$) and Special (RatecodeID$\neq $1) ratecode groups on January 2024 data. Special trips have significantly higher median fares and greater variance, justifying the context-aware approach}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.2}{\ignorespaces Standard vs Special: volume and average fare by time bin. Special trips are consistently 2--3$\times $ higher in average fare across all time slots, demonstrating the need for context-specific thresholds.}}{4}{figure.caption.9}\protected@file@percent }
\newlabel{fig:t7_normal_vs_special}{{2.2}{4}{Standard vs Special: volume and average fare by time bin. Special trips are consistently 2--3$\times $ higher in average fare across all time slots, demonstrating the need for context-specific thresholds}{figure.caption.9}{}}
