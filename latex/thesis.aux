\newlabel{fig:fig1}{{2.4a}{6}{Monthly Record Volume (Jan 2024 -- Feb 2026)\caption@thelabel }{figure.caption.11}{}}
\newlabel{fig:fig2}{{2.4b}{6}{Violation Breakdown by Rule (Jan 2024)\caption@thelabel }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.4}{\ignorespaces (Left) Monthly record volume showing seasonal variations of 2--3$\times $ between peak and off-peak months. January 2024 (training) and July 2024 (test drift) are highlighted. (Right) Violation breakdown by rule type, with NULL passenger and ratecode violations dominating at 278,989 records each.}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{fig:fig3}{{2.5a}{6}{Violation Rate by VendorID across months\caption@thelabel }{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.5}{\ignorespaces Violation rates vary significantly by VendorID. Vendor 6 (Unknown) consistently shows higher violation rates, and Vendor 2 shows distinct seasonal patterns. This vendor-specific variation is captured by context-aware rules but would be missed by a single global threshold.}}{6}{figure.caption.12}\protected@file@percent }
\newlabel{fig:t5}{{2.6a}{7}{Violation counts over time (Jan 2024 -- Feb 2026)\caption@thelabel }{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.6}{\ignorespaces Stacked violation counts over 26 months. The stacked area shows total violations growing with data volume, while the bottom panel reveals the violation rate trends. NULL passenger violations show a gradual increase from 2024 to 2026 --- evidence of gradual concept drift requiring ADWIN-based monitoring.}}{7}{figure.caption.13}\protected@file@percent }
