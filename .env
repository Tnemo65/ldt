# =============================================================================
# CA-DQStream — MemStream-Only Deployment Environment Variables
# Source: deployment/docker-compose.yml, bootstrap.sh, quick_retrain_cron.sh,
#         src/api/ml_service.py
# =============================================================================
# Generated: 2026-05-17
#
# USAGE:
#   1. Copy this file to `C:\proj\ldt\.env`
#   2. Review every variable marked with "CHANGE THIS"
#   3. Generate secure secrets with:
#        openssl rand -hex 32
#   4. Run: docker compose -f deployment/docker-compose.yml up -d
#
# SECURITY NOTE:
#   Variables marked "CHANGE THIS" must be replaced before production use.
#   The placeholder values are for local development only.
# =============================================================================

### ─────────────────────────────────────────────────────────────────────────────
### MCP / External Tooling (preserve these — used by IDE tooling outside Docker)
### ─────────────────────────────────────────────────────────────────────────────

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

### ─────────────────────────────────────────────────────────────────────────────
### MINIO / S3 Storage
### ─────────────────────────────────────────────────────────────────────────────
# Root credentials used by all services to access MinIO.
# Used by: flink-jobmanager, flink-taskmanager, flink-init, ml-service, stats-writer
# Same value is also referenced as MC_MINIO_USER / MC_MINIO_PASSWORD (init container).
# CHANGE THIS in production — use: openssl rand -hex 32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# MinIO Client (mc) credentials used only by the minio-init container to create buckets.
# Defaults to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD for convenience.
MC_MINIO_USER=minioadmin
MC_MINIO_PASSWORD=minioadmin123

### ─────────────────────────────────────────────────────────────────────────────
### Redis — IEC adaptive threshold caching
### ─────────────────────────────────────────────────────────────────────────────
# Used by: flink-jobmanager, flink-taskmanager, ml-service
# Docker internal hostname: redis
REDIS_HOST=redis
REDIS_PASSWORD=redis_password_local   # CHANGE THIS in production

### ─────────────────────────────────────────────────────────────────────────────
### ML Service — FastAPI (Phase 5C)
### ─────────────────────────────────────────────────────────────────────────────
# Bearer token for /api/strategy/retrain_model and /api/strategy/quick_retrain endpoints.
# Used by: ml-service, quick_retrain_cron.sh
# CHANGE THIS — generate with: openssl rand -hex 32
INTERNAL_API_KEY=changeme_internal_api_key_replace_with_openssl_rand_hex32

# Bearer token for /metrics endpoint (Prometheus scraping).
# Used by: ml-service
# Falls back to INTERNAL_API_KEY if not set.
# CHANGE THIS — generate with: openssl rand -hex 32
METRICS_API_KEY=changeme_metrics_api_key_replace_with_openssl_rand_hex32

### ─────────────────────────────────────────────────────────────────────────────
### Model Security — HMAC + SHA256 Verification
### ─────────────────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key used by MemStream scoring operators and ml-service
# to verify model checkpoint authenticity before loading.
# Used by: flink-jobmanager, flink-taskmanager, flink-init, ml-service
# CHANGE THIS — generate with: openssl rand -hex 32
# ALL services in the pipeline MUST share the same key value.
MEMSTREAM_MODEL_SIGNING_KEY=changeme_memstream_signing_key_replace_with_openssl_rand_hex32

# HMAC-SHA256 signing key for IEC (Input Ensemble Controller) communications.
# Used by: flink-jobmanager, flink-taskmanager, flink-init, ml-service
# CHANGE THIS — generate with: openssl rand -hex 32
# Must match the IEC_SIGNING_KEY used by the Flink job operator code.
IEC_SIGNING_KEY=changeme_iec_signing_key_replace_with_openssl_rand_hex32

### ─────────────────────────────────────────────────────────────────────────────
### Grafana — Observability Dashboard
### ─────────────────────────────────────────────────────────────────────────────
# Admin password for Grafana web UI (http://localhost:3000)
# Used by: grafana service
# CHANGE THIS in production
GRAFANA_PASSWORD=grafana_local_admin

### ─────────────────────────────────────────────────────────────────────────────
### Quick Retrain Cron — Phase 5C Automated Retraining
### ─────────────────────────────────────────────────────────────────────────────
# Override these in the cron environment or container if different from defaults.
# ML_SERVICE_URL is set to the Docker internal address in docker-compose.yml.
# The 5 vars below are defaults used by quick_retrain_cron.sh when env vars are unset.

# Grafana URL for anomaly rate queries (fallback only — docker-compose uses internal URL)
GRAFANA_URL=http://localhost:3000

# Grafana service account token (optional — leave blank for local dev without auth)
GRAFANA_TOKEN=

# Prometheus datasource name in Grafana (match the provisioned datasource UID)
GRAFANA_DATASOURCE=Prometheus

# Trigger B: anomaly rate threshold (fraction, 0.15 = 15%)
ANOMALY_RATE_THRESHOLD=0.15

# Trigger B: consecutive days above threshold required to fire retrain
CONSECUTIVE_DAYS=3

### ─────────────────────────────────────────────────────────────────────────────
### Kafka Producer (demo/testing data source)
### ─────────────────────────────────────────────────────────────────────────────
# These are hardcoded in kafka-producer environment block — listed here for documentation.
# Not consumed as ${VAR} — do not move or rename.
# TOPIC_RAW=taxi-nyc-raw-v2
# PRODUCE_DELAY=0.05
# LOOP_INDEFINITELY=true
