# CA-DQStream MCP Server Environment Variables
# Copy to .env and fill in values

# =============================================================================
# Kafka
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=cadqstream-mcp

# =============================================================================
# MinIO (S3-compatible Storage)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKETS=cadqstream-raw,cadqstream-checkpoints,cadqstream-models,cadqstream-dashboard,cadqstream-mlflow
MINIO_USE_SSL=false

# =============================================================================
# Grafana
# =============================================================================
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=<YOUR_GRAFANA_SERVICE_ACCOUNT_TOKEN>

# =============================================================================
# Prometheus
# =============================================================================
PROMETHEUS_URL=http://localhost:9090

# =============================================================================
# Confluent Cloud (Optional - for cloud Kafka)
# =============================================================================
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_ENVIRONMENT_ID=
CONFLUENT_CLUSTER_ID=
CONFLUENT_CLUSTER_REGION=
SCHEMA_REGISTRY_ENDPOINT=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=
KAFKA_REST_ENDPOINT=
KAFKA_CONNECT_ENDPOINT=
